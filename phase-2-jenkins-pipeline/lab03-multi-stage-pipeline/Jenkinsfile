pipeline {
    agent any
    
    stages {
        stage('Checkout') {
            steps {
                echo 'Checking out code from SCM...'
                git 'https://github.com/H1manshu-Kumar/jenkins-devops-learning-labs.git'
            }
        }
        
        stage('Install Dependencies') {
            steps {
                echo 'Setting up Python virtual environment and installing dependencies...'
                sh '''
                    python3 -m venv venv
                    . venv/bin/activate
                    pip install --upgrade pip
                    pip install -r requirements.txt
                '''
            }
        }
        
        stage('Lint') {
            steps {
                echo 'Running flake8 linting on Python files...'
                sh '''
                    . venv/bin/activate
                    flake8 app.py models.py --max-line-length=100
                '''
            }
        }
        
        stage('Test') {
            steps {
                echo 'Running pytest test suite...'
                sh '''
                    . venv/bin/activate
                    pytest tests/ -v
                '''
            }
        }
        
        stage('Build Artifact') {
            steps {
                echo 'Creating build artifact...'
                sh '''
                    zip -r devpulse-build.zip . \
                        -x "*.git*" \
                        -x "*__pycache__*" \
                        -x "*.pyc" \
                        -x "*venv*" \
                        -x "*.db"
                '''
            }
        }
        
        stage('Health Check') {
            steps {
                echo 'Starting Flask app and performing health check...'
                sh '''
                    . venv/bin/activate
                    python app.py &
                    APP_PID=$!
                    echo "Flask app started with PID: $APP_PID"
                    
                    sleep 5
                    
                    HEALTH_RESPONSE=$(curl -s http://localhost:5000/health)
                    echo "Health check response: $HEALTH_RESPONSE"
                    
                    if echo "$HEALTH_RESPONSE" | grep -q '"status": "ok"'; then
                        echo "Health check passed!"
                    else
                        echo "Health check failed!"
                        kill $APP_PID
                        exit 1
                    fi
                    
                    kill $APP_PID
                    echo "Flask app stopped"
                '''
            }
        }
        
        stage('Archive') {
            steps {
                echo 'Archiving build artifact...'
                archiveArtifacts artifacts: 'devpulse-build.zip', fingerprint: true
            }
        }
    }
    
    post {
        always {
            echo 'Pipeline finished'
        }
        success {
            echo 'Build passed'
        }
        failure {
            echo 'Build failed — check logs'
        }
    }
}
