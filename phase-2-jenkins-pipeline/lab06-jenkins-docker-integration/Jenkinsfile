pipeline {

    agent {
        docker {
            image 'python:3.11-slim'
            args '--user root -v /var/run/docker.sock:/var/run/docker.sock'
        }
    }

    environment {
        // - Application metadata
        APP_NAME    = 'devpulse'
        APP_VERSION = "1.0.${BUILD_NUMBER}"

        // - Docker image config
        // - IMPORTANT: Update DOCKERHUB_USERNAME to your DockerHub username
        DOCKERHUB_USERNAME = 'dockerhub-creds'
        IMAGE_NAME         = "${DOCKERHUB_USERNAME}/${APP_NAME}"
        IMAGE_TAG          = "${APP_VERSION}"

        // - Workspace path (consistent with Lab-05)
        APP_DIR = "${WORKSPACE}/phase-2-jenkins-pipeline/devpulse"
    }

    stages {

        // ── Stage 1: Checkout ────────────────────────────────────────────
        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        // ── Stage 2: Setup Python Environment ────────────────────────────
        stage('Setup') {
            steps {
                dir("${APP_DIR}") {
                    sh '''
                        python3 -m venv venv
                        . venv/bin/activate
                        pip install --upgrade pip
                        pip install -r requirements.txt
                    '''
                }
            }
        }

        // ── Stage 3: Lint ─────────────────────────────────────────────────
        stage('Lint') {
            steps {
                dir("${APP_DIR}") {
                    sh '''
                        . venv/bin/activate
                        flake8 *.py --max-line-length=100
                    '''
                }
            }
        }

        // ── Stage 4: Test ─────────────────────────────────────────────────
        stage('Test') {
            steps {
                dir("${APP_DIR}") {
                    sh '''
                        . venv/bin/activate
                        mkdir -p reports
                        pytest tests/ \
                            --junitxml=reports/junit.xml \
                            --cov=. \
                            --cov-report=xml:reports/coverage.xml \
                            -v
                    '''
                }
            }
            post {
                always {
                    junit allowEmptyResults: true,
                          testResults: "${APP_DIR}/reports/junit.xml"
                }
            }
        }

        // ── Stage 5: Install Docker CLI ───────────────────────────────────
        // - Docker CLI is NOT in python:3.11-slim by default
        // - We install it here so the agent can run docker commands
        // - The socket mount (-v /var/run/docker.sock) lets it talk to host daemon
        stage('Install Docker CLI') {
            steps {
                sh '''
                    apt-get update -qq
                    apt-get install -y --no-install-recommends docker.io
                    docker --version
                '''
            }
        }

        // ── Stage 6: Docker Build ─────────────────────────────────────────
        stage('Docker Build') {
            steps {
                dir("${APP_DIR}") {
                    script {
                        echo "Building Docker image: ${IMAGE_NAME}:${IMAGE_TAG}"
                        sh """
                            docker build \
                                --no-cache \
                                --label "build.number=${BUILD_NUMBER}" \
                                --label "build.version=${APP_VERSION}" \
                                --label "git.commit=${GIT_COMMIT}" \
                                -t ${IMAGE_NAME}:${IMAGE_TAG} \
                                -t ${IMAGE_NAME}:latest \
                                -f Dockerfile \
                                .
                        """
                        // - Verify image was built successfully
                        sh "docker images ${IMAGE_NAME}"
                    }
                }
            }
        }

        // ── Stage 7: Docker Login ─────────────────────────────────────────
        // - Credentials stored in Jenkins Credentials Store (never hardcoded)
        // - ID 'dockerhub-creds' must match what you configured in Jenkins
        stage('Docker Login') {
            steps {
                withCredentials([usernamePassword(
                    credentialsId: 'dockerhub-creds',
                    usernameVariable: 'DOCKER_USER',
                    passwordVariable: 'DOCKER_PASS'
                )]) {
                    sh 'echo "$DOCKER_PASS" | docker login -u "$DOCKER_USER" --password-stdin'
                }
            }
        }

        // ── Stage 8: Docker Push ──────────────────────────────────────────
        // - Push both versioned tag AND latest tag
        // - Versioned tag = traceability & rollback
        // - Latest tag = convenience for dev/staging pulls
        stage('Docker Push') {
            steps {
                script {
                    echo "Pushing image: ${IMAGE_NAME}:${IMAGE_TAG}"
                    sh "docker push ${IMAGE_NAME}:${IMAGE_TAG}"

                    echo "Pushing image: ${IMAGE_NAME}:latest"
                    sh "docker push ${IMAGE_NAME}:latest"

                    echo "Successfully pushed to DockerHub:"
                    echo "  - ${IMAGE_NAME}:${IMAGE_TAG}"
                    echo "  - ${IMAGE_NAME}:latest"
                }
            }
        }

        // ── Stage 9: Validate Image (Smoke Test) ─────────────────────────
        // - Pull back the pushed image and do a quick smoke test
        // - Confirms the image is actually pullable from registry
        // - Simulates what a deployment pipeline would do
        stage('Validate Image') {
            steps {
                script {
                    sh """
                        echo "Pulling image back from DockerHub for validation..."
                        docker pull ${IMAGE_NAME}:${IMAGE_TAG}

                        echo "Running smoke test - checking app starts without crash..."
                        docker run --rm \
                            --name devpulse-smoke-test \
                            ${IMAGE_NAME}:${IMAGE_TAG} \
                            python -c "from app import app; print('DevPulse import OK')"
                    """
                }
            }
        }
    }

    // ── Post-Build Actions ────────────────────────────────────────────────
    post {
        success {
            echo """
            ============================================
            DevPulse Docker Image Published Successfully
            ============================================
            Image   : ${env.IMAGE_NAME}:${env.IMAGE_TAG}
            Version : ${env.APP_VERSION}
            Build   : #${env.BUILD_NUMBER}
            Commit  : ${env.GIT_COMMIT}
            Registry: https://hub.docker.com/r/${env.IMAGE_NAME}
            ============================================
            """
        }
        failure {
            echo "Pipeline failed. Check logs above for details."
        }
    }
}
