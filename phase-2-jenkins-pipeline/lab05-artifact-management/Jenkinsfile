pipeline {
    agent {
        label 'docker'
    }

    environment {
        AWS_ACCESS_KEY_ID     = credentials('aws-access-key-id')
        AWS_SECRET_ACCESS_KEY = credentials('aws-secret-access-key')
        AWS_DEFAULT_REGION    = 'ap-south-1'
        S3_BUCKET             = 'jenkins-artifacts-devops1'
        APP_VERSION           = "1.0.${BUILD_NUMBER}"
    }

    options {
        timestamps()
        buildDiscarder(logRotator(numToKeepStr: '5'))
    }

    stages {

        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Setup') {
            steps {
                dir("${WORKSPACE}/phase-2-jenkins-pipeline/devpulse") {
                    sh '''
                        python3 -m venv venv
                        . venv/bin/activate
                        pip install --upgrade pip
                        pip install -r requirements.txt
                    '''
                }
            }
        }

        stage('Lint') {
            steps {
                dir("${WORKSPACE}/phase-2-jenkins-pipeline/devpulse") {
                    sh '''
                        . venv/bin/activate
                        flake8 *.py --max-line-length=100
                    '''
                }
            }
        }

        stage('Test') {
            steps {
                dir("${WORKSPACE}/phase-2-jenkins-pipeline/devpulse") {
                    sh '''
                        . venv/bin/activate
                        pytest tests/ \
                            --junitxml=reports/junit.xml \
                            --cov=. \
                            --cov-report=xml:reports/coverage.xml \
                            -v
                    '''
                }
            }
            post {
                always {
                    junit "${WORKSPACE}/phase-2-jenkins-pipeline/devpulse/reports/junit.xml"
                }
            }
        }

        stage('Build') {
            steps {
                dir("${WORKSPACE}/phase-2-jenkins-pipeline/devpulse") {
                    sh '''
                        . venv/bin/activate
                        python3 -m build
                    '''
                }
            }
        }

        stage('Archive') {
            steps {
                dir("${WORKSPACE}/phase-2-jenkins-pipeline/devpulse") {
                    archiveArtifacts artifacts: 'dist/**'
                }
            }
        }

        stage('Upload to S3') {
            steps {
                dir("${WORKSPACE}/phase-2-jenkins-pipeline/devpulse") {
                    sh '''
                        echo "Uploading artifacts for version ${APP_VERSION}"

                        aws s3 cp dist/ s3://${S3_BUCKET}/devpulse/${APP_VERSION}/ \
                            --recursive \
                            --no-progress

                        echo "Upload complete. Verifying..."

                        aws s3 ls s3://${S3_BUCKET}/devpulse/${APP_VERSION}/
                    '''
                }
            }
        }

    }

    post {
        always {
            cleanWs()
        }
        success {
            echo "Pipeline succeeded. Artifacts at s3://${S3_BUCKET}/devpulse/${APP_VERSION}/"
        }
        failure {
            echo "Pipeline failed. Check logs above."
        }
    }
}
